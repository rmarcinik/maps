{
  "version": 8,
  "name": "OLED",
  "glyphs": "https://fonts.openmaptiles.org/{fontstack}/{range}.pbf",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#000000" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#04040a" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#04040a",
        "line-width": 0.5
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "match",
        ["get", "class"],
        ["path", "track", "footway"],
        true,
        false
      ],
      "minzoom": 14,
      "paint": {
        "line-color": "#1c1c1c",
        "line-width": 0.5,
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "road-service",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "service"],
      "minzoom": 13,
      "paint": {
        "line-color": "#282828",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.3, 18, 1.5]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "minor"],
      "minzoom": 12,
      "paint": {
        "line-color": "#383838",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          0.3,
          15,
          1,
          18,
          2
        ]
      }
    },
    {
      "id": "road-tertiary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "tertiary"],
      "paint": {
        "line-color": "#555555",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10,
          0.3,
          14,
          1,
          18,
          2.5
        ]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "secondary"],
      "paint": {
        "line-color": "#888888",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          0.3,
          12,
          1.5,
          18,
          3
        ]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "primary"],
      "paint": {
        "line-color": "#bbbbbb",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          7,
          0.3,
          12,
          2,
          18,
          4
        ]
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "trunk"],
      "paint": {
        "line-color": "#dedede",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5,
          0.3,
          10,
          2,
          18,
          5
        ]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "motorway"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          4,
          0.3,
          8,
          1.5,
          14,
          3,
          18,
          6
        ]
      }
    },
    {
      "id": "road-name-data",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 14,
      "paint": { "line-opacity": 0, "line-width": 1 }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", ["get", "class"], "village"],
      "minzoom": 10,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#777777",
        "text-halo-color": "#000000",
        "text-halo-width": 1
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", ["get", "class"], "town"],
      "minzoom": 8,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 12,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#aaaaaa",
        "text-halo-color": "#000000",
        "text-halo-width": 1
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "match",
        ["get", "class"],
        ["city", "metropolis"],
        true,
        false
      ],
      "minzoom": 5,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 12, 10, 16],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#ffffff",
        "text-halo-color": "#000000",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-country",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", ["get", "class"], "country"],
      "minzoom": 2,
      "maxzoom": 8,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 2, 10, 6, 14],
        "text-max-width": 6,
        "text-letter-spacing": 0.1
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "#000000",
        "text-halo-width": 1
      }
    }
  ]
}
